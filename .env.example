# ── Copy this to .env and fill in your values ──

# AI Provider: "anthropic" (default) or "ollama"
AI_PROVIDER=anthropic

# Anthropic (used when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama (used when AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# Haystack RAG (optional)
# Run: docker exec -it marzano-backend python haystack_pipeline.py index /path/to/marzano.pdf
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
